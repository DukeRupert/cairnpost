package pages

import "github.com/dukerupert/cairnpost/web/templates/layouts"

templ Companies() {
	@layouts.Base("Companies", "/companies") {
		<div class="max-w-4xl">
			<h1 class="text-2xl font-semibold text-gray-900">Companies</h1>
			<p class="mt-2 text-gray-500">Company list will appear here.</p>
		</div>
	}
}
