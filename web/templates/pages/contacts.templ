package pages

import "github.com/dukerupert/cairnpost/web/templates/layouts"

templ Contacts() {
	@layouts.Base("Contacts", "/contacts") {
		<div class="max-w-4xl">
			<h1 class="text-2xl font-semibold text-gray-900">Contacts</h1>
			<p class="mt-2 text-gray-500">Contact list will appear here.</p>
		</div>
	}
}
